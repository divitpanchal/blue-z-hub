-- Fade in text while expanding
local fadeIn = TweenService:Create(popupText, TweenInfo.new(0.5), {TextTransparency = 0})
fadeIn:Play()

-- Tween to expand slowly
local tweenExpand = TweenService:Create(frame, TweenInfo.new(1.5, Enum.EasingStyle.Quint, Enum.EasingDirection.Out),
    {Size = UDim2.new(0, 340, 0, 260), Position = UDim2.new(0.5, -170, 0.5, -130)})
tweenExpand:Play()
tweenExpand.Completed:Wait()

-- Fade out text after expansion
local fadeOut = TweenService:Create(popupText, TweenInfo.new(0.5), {TextTransparency = 1})
fadeOut:Play()
fadeOut.Completed:Wait()
popupText:Destroy()

