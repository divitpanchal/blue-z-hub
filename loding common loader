-- Create ScreenGui
local ScreenGui = Instance.new("ScreenGui")
ScreenGui.Parent = game.Players.LocalPlayer:WaitForChild("PlayerGui")

-- Circle (initial shape)
local Circle = Instance.new("Frame")
Circle.Size = UDim2.new(0, 100, 0, 100)
Circle.Position = UDim2.new(0.5, -50, 0.1, 0) -- top center
Circle.AnchorPoint = Vector2.new(0.5, 0)
Circle.BackgroundColor3 = Color3.fromRGB(0, 200, 255)
Circle.Parent = ScreenGui

-- Make it circular
local CircleCorner = Instance.new("UICorner")
CircleCorner.CornerRadius = UDim.new(1, 0)
CircleCorner.Parent = Circle

-- TweenService for animation
local TweenService = game:GetService("TweenService")

-- Tween: morph circle into rounded rectangle
local goal = {}
goal.Size = UDim2.new(0.3, 0, 0.15, 0) -- rectangle size
goal.Position = UDim2.new(0.35, 0, 0.1, 0) -- reposition slightly
local tweenInfo = TweenInfo.new(2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
local tween = TweenService:Create(Circle, tweenInfo, goal)
tween:Play()

-- After tween, adjust corner radius for rounded rectangle
tween.Completed:Connect(function()
    CircleCorner.CornerRadius = UDim.new(0, 20)

    -- Add text
    local TextLabel = Instance.new("TextLabel")
    TextLabel.Size = UDim2.new(1, 0, 1, 0)
    TextLabel.BackgroundTransparency = 1
    TextLabel.Text = "Update is here"
    TextLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
    TextLabel.TextSize = 22
    TextLabel.Font = Enum.Font.SourceSansBold
    TextLabel.Parent = Circle

    -- Fade in text
    TextLabel.TextTransparency = 1
    local textTween = TweenService:Create(TextLabel, TweenInfo.new(1), {TextTransparency = 0})
    textTween:Play()

    -- Wait before executing your loader GUI
    task.wait(2)

local ScreenGui = Instance.new("ScreenGui")
ScreenGui.Parent = game.Players.LocalPlayer.PlayerGui
local Frame = Instance.new("Frame")
Frame.Size = UDim2.new(0.3, 0, 0.2, 0)
Frame.Position = UDim2.new(0.35, 0, 0.4, 0)
Frame.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
Frame.Parent = ScreenGui
local Corner = Instance.new("UICorner")
Corner.CornerRadius = UDim.new(0, 10)
Corner.Parent = Frame
local Text = Instance.new("TextLabel")
Text.Size = UDim2.new(1, 0, 0.8, 0)
Text.Position = UDim2.new(0, 0, 0.1, 0)
Text.BackgroundTransparency = 1
Text.Text = "Loading Blue X hub by supperdupperhacke"
Text.TextColor3 = Color3.fromRGB(0, 255, 127)
Text.TextSize = 20
Text.Font = Enum.Font.SourceSansBold
Text.TextWrapped = true
Text.Parent = Frame
task.wait(2) -- Display for 5 seconds
loadstring(game:HttpGet("https://raw.githubusercontent.com/divitpanchal/blue-z-hub/refs/heads/main/common%20loader"))()
ScreenGui:Destroy()
